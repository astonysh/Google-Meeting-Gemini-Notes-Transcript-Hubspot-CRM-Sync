# Google OAuth2 Credentials
# Create a "Web application" OAuth2 client at https://console.cloud.google.com/
# Add http://localhost:3333/callback as an authorized redirect URI
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token   # Run: npm run get-token

# HubSpot Private App Token
# Create at: HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Sync settings
MEET_SYNC_LOOKBACK_HOURS=25       # How many hours back to search for new Gemini notes
MEET_SYNC_MATCH_WINDOW_MIN=10     # Match window in minutes (±) for HubSpot meeting lookup
